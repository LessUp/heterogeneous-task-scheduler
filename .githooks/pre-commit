#!/bin/bash

set -euo pipefail

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

mapfile -t STAGED_FILES < <(git diff --cached --name-only --diff-filter=ACMR)

if [ "${#STAGED_FILES[@]}" -eq 0 ]; then
    exit 0
fi

echo "[hts hook] Checking staged diff integrity..."
git diff --cached --check

FORMAT_TARGETS=()
for file in "${STAGED_FILES[@]}"; do
    case "$file" in
        src/*|include/*|tests/*|examples/*)
            case "$file" in
                *.cpp|*.hpp|*.cu|*.cuh)
                    FORMAT_TARGETS+=("$file")
                    ;;
            esac
            ;;
    esac
done

if [ "${#FORMAT_TARGETS[@]}" -eq 0 ]; then
    exit 0
fi

if command -v clang-format-17 >/dev/null 2>&1; then
    CLANG_FORMAT="clang-format-17"
elif command -v clang-format >/dev/null 2>&1; then
    CLANG_FORMAT="clang-format"
else
    echo "[hts hook] clang-format not found. Install clang-format-17 or clang-format."
    exit 1
fi

echo "[hts hook] Checking staged C++/CUDA formatting..."
FAILED=0
for file in "${FORMAT_TARGETS[@]}"; do
    if ! "$CLANG_FORMAT" --dry-run --Werror -style=file "$file"; then
        echo "[hts hook] Formatting required: $file"
        FAILED=1
    fi
done

if [ "$FAILED" -ne 0 ]; then
    echo "[hts hook] Run scripts/format.sh or format the staged files before committing."
    exit 1
fi
